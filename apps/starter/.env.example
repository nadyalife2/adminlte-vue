# Copy to .env and fill in. Exposed values must be prefixed per Nuxt runtimeConfig.

# Public (sent to the browser) — see nuxt.config.ts runtimeConfig.public
NUXT_PUBLIC_APP_NAME="AdminLTE Starter"

# Private (server only) — add your real auth/database secrets here, e.g.
# NUXT_AUTH_SECRET="change-me"
# NUXT_DATABASE_URL="postgres://user:pass@localhost:5432/app"
