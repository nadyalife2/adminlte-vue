{
  "name": "adminlte-vue-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --filter ./packages/* run build",
    "build:demo": "pnpm --filter demo run build",
    "dev:demo": "pnpm --filter demo run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm --filter adminlte-vue test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0"
  },
  "packageManager": "pnpm@9.12.0"
}
