{
  "name": "adminlte-vue-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --filter ./packages/* run build",
    "build:demo": "pnpm --filter demo run build",
    "dev:demo": "pnpm --filter demo run dev",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm --filter adminlte-vue test"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
