{
  "name": "@adminlte/nuxt",
  "version": "0.1.0",
  "description": "Nuxt module for adminlte-vue — auto-imports, CSS, Bootstrap init, and SSR-safe theming",
  "license": "MIT",
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": ["nuxt", "nuxt-module", "adminlte", "vue", "bootstrap", "dashboard"],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "prepare": "nuxt-module-build prepare",
    "type-check": "echo 'type-check: skipped for module'",
    "lint": "echo 'linting @adminlte/nuxt...'"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "adminlte-vue": "workspace:*",
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "nuxt": "^4.4.6",
    "typescript": "^5.6.3",
    "vue": "^3.5.35"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "bootstrap": { "optional": true }
  }
}
